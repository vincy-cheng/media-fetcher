{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Media Fetcher",
  "version": "0.1.0",
  "identifier": "com.github.media-fetcher",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev --prefix client",
    "beforeBuildCommand": "npm run build --prefix client"
  },
  "app": {
    "windows": [
      {
        "title": "Media Fetcher",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/yt-dlp",
      "binaries/ffmpeg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
