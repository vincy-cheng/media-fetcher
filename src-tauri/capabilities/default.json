{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl-manifests/acl.schema.json",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-app-read",
    "fs:allow-temp-read",
    "fs:allow-temp-write"
  ]
}
